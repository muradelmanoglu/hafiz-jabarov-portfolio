# Copy this file to .env.local and fill in the values

# Backend URL (used in Next.js rewrites - server side)
BACKEND_URL=http://localhost:8080

# Admin panel path - keep this SECRET, do not commit .env.local
# Example: NEXT_PUBLIC_ADMIN_PATH=x7f2a9b4 → access via http://localhost:3000/x7f2a9b4
NEXT_PUBLIC_ADMIN_PATH=studio
